# Arma 3 Server Framework - Environment Configuration
# -------------------------------------------------------
# Copy this file to .env and fill in your actual values.
# .env is git-ignored and will NEVER be committed.
#
# Rules:
#   - Comments must be on their OWN line (starting with #)
#   - NO inline comments after values  ->  KEY=value  # this breaks things
#   - Quotes around values are optional but recommended for paths with spaces
#   - Paths with # in them (e.g. C:\#Folder) work fine when properly quoted
# -------------------------------------------------------

# Path where the Arma 3 Dedicated Server (App ID 233780) is installed.
SERVER_INSTALL_PATH=D:\Arma3Server

# Path where SteamCMD is (or will be) installed.
STEAMCMD_PATH=D:\SteamCMD

# Temporary directory used by SteamCMD to download Workshop mods before deployment.
WORKSHOP_STAGING_PATH=D:\Arma3Workshop

# Steam account username. The account must own Arma 3 for Workshop downloads.
STEAM_USERNAME=your_steam_username

# Optional: Steam password.
# If set, scripts will NOT prompt interactively (useful for automated / scheduled tasks).
# Leave empty or comment out to always prompt (safer).
# STEAM_PASSWORD=

# ── Discord Bot ────────────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_bot_token_here

# Right-click your Discord server → Copy Server ID (enable Developer Mode first)
DISCORD_GUILD_ID=your_guild_id_here

# Comma-separated role IDs whose members are allowed to use bot commands
# Right-click a role → Copy Role ID (enable Developer Mode first)
# Multiple roles: DISCORD_ADMIN_ROLE_IDS=123456789,987654321
DISCORD_ADMIN_ROLE_IDS=your_admin_role_id_here

# Optional: comma-separated user IDs that bypass role checks (always have access)
# DISCORD_ADMIN_USER_IDS=242292116833697792

# ── Bot SSH Connection (container → host) ──────────────────────────────────────
# Windows username created by bot/setup-ssh-key.ps1
BOT_SSH_USER=arma_bot

# Leave as-is when running via docker compose (resolves to the Windows host)
BOT_SSH_HOST=host.docker.internal
BOT_SSH_PORT=22

# Path to the SSH private key *inside* the container (mounted via docker-compose.yml)
BOT_SSH_KEY_PATH=/app/ssh_key

# Absolute path to this repository on the Windows host
# The bot uses this to build the full path to each PowerShell script
BOT_SCRIPTS_PATH="C:\#Arma Server\Framework\Arma-3-Server"
