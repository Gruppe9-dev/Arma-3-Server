# Arma 3 Server Framework - Environment Configuration
# -------------------------------------------------------
# Copy this file to .env and fill in your actual values.
# .env is git-ignored and will NEVER be committed.
#
# Rules:
#   - Comments must be on their OWN line (starting with #)
#   - NO inline comments after values  ->  KEY=value  # this breaks things
#   - Quotes around values are optional but recommended for paths with spaces
#   - Paths with # in them (e.g. C:\#Folder) work fine when properly quoted
# -------------------------------------------------------

# Path where the Arma 3 Dedicated Server (App ID 233780) is installed.
SERVER_INSTALL_PATH=D:\Arma3Server

# Path where SteamCMD is (or will be) installed.
STEAMCMD_PATH=D:\SteamCMD

# Temporary directory used by SteamCMD to download Workshop mods before deployment.
WORKSHOP_STAGING_PATH=D:\Arma3Workshop

# Steam account username. The account must own Arma 3 for Workshop downloads.
STEAM_USERNAME=your_steam_username

# Optional: Steam password.
# If set, scripts will NOT prompt interactively (useful for automated / scheduled tasks).
# Leave empty or comment out to always prompt (safer).
# STEAM_PASSWORD=
