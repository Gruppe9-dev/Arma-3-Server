# Environment / secrets - never commit
.env

# Profiles — only _template is tracked in Git.
# All other profile directories (main, star_wars, …) are local-only.
profiles/*/
!profiles/_template/

# Mod presets (HTML files imported via /mods import-preset) — local-only.
presets/

# SteamCMD (lives outside the repo, but guard against accidental add)
steamcmd/
SteamCMD/

# Discord bot SSH keys (generated by bot/setup-ssh-key.ps1 – never commit)
bot/ssh_key
bot/ssh_key.pub

# Auto-pull log
logs/auto-pull.log

# Discord bot runtime logs
bot/logs/

# Windows
Thumbs.db
Desktop.ini
